# === Global Functions ===

# Esc and :q to exit
cmd q quit

# === Global Options ===

# Nicer Looks (Icons and Previewer)
set icons
# Change Tabstop
# set tabstop 4
set timefmt '_2 Jan 2006 15:04:05'

# Deprecated
# set color256

# Show Number of Files in Dir, when Displaying Size (set info "size")
set dircounts

# Enable Search with Globs (e.g. *)
set globsearch
# Disable wierd case sensitive stuff
# set nosmartcase
set noignorecase

# Enable Hidden Files by Default
# set hidden
# Don't show git Directories
set hiddenfiles .git

# leave some space at the top and the bottom of the screen
set scrolloff 5
# Enable Scrolling from top to bottom
set wrapscroll
# Better proportions
set ratios 1:2:2

set truncatechar 

# (POSIX compatible (?)) interpreter for shell commands
set shell bash
# Safer shell commands: '-e' to exit on error,
# '-u' to give error for unset variables
# '-u' is not used, because of the GIT_OPTIONS
set shellopts '-e'
# set internal field separator (IFS) to "\n" for shell commands
# set ifs "\n"
# set filesep "\n"

# Reload files every second
set period 1

# Active Globs (requires my fork)
set globcolor
set globicon

# === Mode Setup ===

# Load other mapping files and enable normal mode
# (The Default Mappings are Loaded everytime the mode is changed)
source ~/.config/lf/common_commands.lf
source ~/.config/lf/clear_mappings.lf
source ~/.config/lf/normal_mode_mappings.lf
source ~/.config/lf/git_mode_mappings.lf

enable_normal_mode

