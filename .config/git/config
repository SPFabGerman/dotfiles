[alias]
    graph = log --oneline --graph --decorate
    purr = pull --rebase
    unstage = restore --staged
    lf = !lf -command=\"enable_git_mode\"
[core]
    editor = nvim
[init]
	defaultBranch = main
[pull]
    ff = only
[push]
	autoSetupRemote = true
[icdiff]
	options = --highlight --line-numbers
